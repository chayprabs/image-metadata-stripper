{
  "name": "@exifscrub/core",
  "version": "1.0.0",
  "description": "Browser-side metadata read, scrub, diff, and prove-clean for ExifScrub",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "lint": "echo ok",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "license": "MIT",
  "dependencies": {
    "exifr": "^7.1.3",
    "pdf-lib": "^1.17.1",
    "heic2any": "^0.0.4",
    "piexifjs": "^1.0.6",
    "png-chunks-extract": "^1.0.0",
    "png-chunks-encode": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
